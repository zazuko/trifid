{
  "name": "@zazuko/trifid-markdown-content",
  "version": "2.0.5",
  "description": "Trifid plugin to handle Markdown files",
  "main": "./dist/src/index.js",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='**/types/**' --exclude='test/**' --exclude=dist --exclude=scripts --exclude=coverage --reporter=lcovonly --reporter=text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc && node scripts/copy-assets.ts",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/markdown-content"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "markdown-content"
  ],
  "dependencies": {
    "hast-util-select": "^6.0.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "fastify": "^5.8.5",
    "rimraf": "^6.1.3",
    "trifid-core": "workspace:^",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
