{
  "name": "trifid-plugin-i18n",
  "version": "3.0.3",
  "description": "Trifid plugin for i18n support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='test/**' --exclude=dist --exclude=coverage --reporter=lcovonly --reporter=text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc",
    "prepack": "npm run clean && npm run build"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/zazuko/trifid.git",
    "directory": "packages/i18n"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "homepage": "https://github.com/zazuko/trifid",
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "i18n"
  ],
  "dependencies": {
    "i18n": "^0.15.3"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/i18n": "^0.13.12",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "rimraf": "^6.1.3",
    "trifid-core": "^5.1.0",
    "typescript": "^5.9.3"
  },

  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
