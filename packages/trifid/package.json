{
  "name": "trifid",
  "description": "Trifid - Lightweight Linked Data Server and Proxy",
  "version": "5.3.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/zazuko/trifid",
  "type": "module",
  "main": "./dist/server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/trifid"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "scripts": {
    "help": "node server.ts --help",
    "start:tbbt": "node server.ts -c instances/tbbt/config.yaml",
    "start": "npm run start:tbbt",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc && node scripts/copy-assets.ts",
    "prepack": "npm run clean && npm run build"
  },
  "bin": {
    "trifid": "./dist/server.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "linked-data"
  ],
  "dependencies": {
    "@zazuko/trifid-plugin-sparql-proxy": "^2.9.1",
    "@zazuko/trifid-entity-renderer": "^1.6.1",
    "commander": "^14.0.3",
    "trifid-core": "^5.3.2",
    "trifid-handler-fetch": "^3.5.1",
    "trifid-plugin-graph-explorer": "^2.2.0",
    "trifid-plugin-i18n": "^3.0.2",
    "trifid-plugin-spex": "^3.0.0",
    "trifid-plugin-yasgui": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
