{
  "name": "trifid",
  "description": "Trifid - Lightweight Linked Data Server and Proxy",
  "version": "6.0.1",
  "license": "Apache-2.0",
  "homepage": "https://github.com/zazuko/trifid",
  "type": "module",
  "main": "./dist/server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/trifid"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "scripts": {
    "help": "node server.ts --help",
    "start:tbbt": "node server.ts -c instances/tbbt/config.yaml",
    "start": "pnpm run start:tbbt",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc && node scripts/copy-assets.ts"
  },
  "bin": {
    "trifid": "./dist/server.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "linked-data"
  ],
  "dependencies": {
    "@zazuko/trifid-plugin-sparql-proxy": "workspace:^",
    "@zazuko/trifid-entity-renderer": "workspace:^",
    "commander": "^15.0.0",
    "trifid-core": "workspace:^",
    "trifid-handler-fetch": "workspace:^",
    "trifid-plugin-graph-explorer": "workspace:^",
    "trifid-plugin-i18n": "workspace:^",
    "trifid-plugin-spex": "workspace:^",
    "trifid-plugin-yasgui": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
