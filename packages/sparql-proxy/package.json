{
  "name": "@zazuko/trifid-plugin-sparql-proxy",
  "version": "2.9.1",
  "description": "Trifid plugin for sparql-proxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/zazuko/trifid",
  "scripts": {
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='test/**' --exclude=dist --exclude=coverage --reporter lcovonly --reporter text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc",
    "prepack": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/sparql-proxy"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "sparql-proxy"
  ],
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@vocabulary/sd": "^1.0.6",
    "@zazuko/env-node": "^3.0.0",
    "trifid-core": "^5.3.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
