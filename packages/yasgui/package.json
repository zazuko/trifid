{
  "name": "trifid-plugin-yasgui",
  "description": "Trifid YASGUI plugin",
  "type": "module",
  "version": "3.4.5",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "homepage": "https://github.com/zazuko/trifid",
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/yasgui"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "esbuild --minify --bundle plugins/map.js --outdir=build --splitting --format=esm",
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='test/**' --exclude=dist --exclude=scripts --exclude=build --exclude=coverage --reporter=lcovonly --reporter=text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "prebuild": "npm run clean && npm run prepare",
    "build": "tsc && node scripts/copy-assets.ts",
    "prepack": "npm run build"
  },
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "yasgui"
  ],
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@zazuko/yasgui": "^4.6.1",
    "import-meta-resolve": "^4.2.0"
  },
  "devDependencies": {
    "@openlayers-elements/maps": "^0.5.0",
    "@openlayers-elements/swisstopo": "^0.4.0",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "trifid-core": "^5.1.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
