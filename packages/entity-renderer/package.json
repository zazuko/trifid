{
  "name": "@zazuko/trifid-entity-renderer",
  "version": "2.0.0",
  "type": "module",
  "description": "Renders a RDF entity in Trifid",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "example-instance": "node ./examples/run-instance.js",
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='**/types/**' --exclude='test/**' --exclude=dist --exclude=scripts --exclude=coverage --reporter lcovonly --reporter text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc && node scripts/copy-assets.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/entity-renderer"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "homepage": "https://github.com/zazuko/trifid#readme",
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "entity-renderer"
  ],
  "dependencies": {
    "@lit-labs/ssr": "^4.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@rdfjs/formats-common": "^3.1.0",
    "@rdfjs/to-ntriples": "^3.0.1",
    "@zazuko/env": "^3.0.1",
    "@zazuko/prefixes": "^2.6.1",
    "@zazuko/rdf-entity-webcomponent": "^0.7.7",
    "lit": "^3.3.3",
    "mimeparse": "^0.1.4",
    "p-queue": "^9.1.1",
    "trifid-core": "workspace:^"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "fastify": "^5.10.0",
    "rimraf": "^6.1.3",
    "trifid-handler-fetch": "workspace:^",
    "trifid-plugin-yasgui": "workspace:^",
    "typescript": "^7.0.2"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
