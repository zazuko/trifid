<style>
  body {
    --border: var(--trifid-color-border, #e8e4df);
    --metadata: var(--trifid-color-text-muted, #6f6a64);
    --color-black: var(--trifid-color-text, #1c1917);
    --entity-surface: var(--trifid-color-surface, #faf9f7);
    --entity-radius: var(--trifid-radius, 10px);
  }

  /* Entity renderer CSS */
  .entities {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .entity {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--entity-radius);
    background: #fff;
    box-shadow: var(--trifid-shadow-sm, 0 1px 2px rgba(0, 0, 0, .05));
    overflow: hidden;
  }

  /* Nested entities are lighter: no card chrome */
  .entity .entity {
    border: 1px solid var(--border);
    box-shadow: none;
    background: var(--entity-surface);
  }

  .entity-header {
    padding: 12px 20px;
    background: var(--entity-surface);
    font-weight: 500;
    word-break: break-word;
  }

  .rows {
    display: flex;
    flex-direction: column;
  }

  .rows > * + * {
    border-top: 1px solid var(--border);
  }

  .rows > .row {
    display: flex;
    flex-direction: row;
    transition: background .1s ease;
  }

  .rows > .row:hover {
    background: rgba(247, 127, 0, .035);
  }

  .row > .property {
    align-self: flex-start;
    flex: 0 0 30%;
    word-break: break-word;
    margin: 0;
    padding: 12px 16px 12px 20px;
    font-weight: 500;
  }

  /* Values */
  .row > .value {
    flex: 1;
    min-width: 0;
    word-break: break-word;
    margin: 0;
    padding: 12px 20px 12px 16px;
  }

  @media screen and (max-width: 720px) {
    .rows > .row {
      flex-direction: column;
    }

    .row > .property {
      flex: none;
      padding-bottom: 0;
    }

    .row > .value {
      padding-top: 4px;
      padding-left: 20px;
    }
  }

  .entities ul,
  .entities ol {
    display: flex;
    flex-direction: column;
    list-style: none;
    gap: 6px;
    justify-content: center;
    padding-left: 0;
  }

  div .bring-down {
    color: var(--metadata);
  }

  .vocab,
  .language,
  .datatype {
    display: inline-block;
    color: var(--metadata);
    font-family: var(--trifid-font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    line-height: 1.4;
    vertical-align: middle;
  }

  .vocab::after {
    content: ':';
  }

  .language,
  .datatype {
    margin-left: 6px;
    padding: 0 6px;
    background: var(--entity-surface);
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  .img-container {
    margin: 4px 0;
  }

  .img-container img {
    max-width: 200px;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  /* Metadata CSS */
  .metadata-table {
    margin: 48px 0 0;
    width: 100%;
    text-align: left;
    border: 1px solid var(--border);
    border-radius: var(--entity-radius);
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    font-size: .95rem;
  }
  .metadata-table th {
    background-color: var(--entity-surface);
    border-bottom: 1px solid var(--border);
    padding: 10px 20px;
    font-size: .8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--metadata);
  }
  .metadata-table td {
    border-bottom: 1px solid var(--border);
    padding: 10px 20px;
  }
  .metadata-table tr:last-child td {
    border-bottom: none;
  }
  .metadata-table > caption {
    caption-side: top;
    text-align: left;
    padding: 0 0 12px;
    font-weight: 600;
    color: var(--color-black);
  }
</style>

{{#if entityLabel}}
  <div class="trifid-header-title">
    <div class="trifid-content">
      <div class="container">
        <h1>{{entityLabel}}</h1>
        <p><a class="trifid-badge" href="{{entityUrl}}">{{entityUrl}}</a></p>
      </div>
    </div>
  </div>
{{/if}}

<div class="trifid-content">
  <div class="container">
    <meta property="dc:title" content="{{entityLabel}}" />

    {{{ dataset }}}

    {{#if metadata.namedGraphs}}
      <table class="metadata-table">
        <caption>Number of results per named graph</caption>
        <thead>
          <tr>
            <th>Graph name</th>
            <th>Number of results</th>
          </tr>
        </thead>
        <tbody>
          {{#each metadata.namedGraphs}}
            <tr>
              {{#if this.namedGraph}}
                <td><a href="{{this.namedGraph}}">{{this.namedGraphLabel}}</a></td>
              {{/if}}
              {{#unless this.namedGraph}}
                <td>{{this.namedGraphLabel}}</td>
              {{/unless}}
              <td>{{this.quadsCount}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{/if}}
  </div>
</div>
