{
  "name": "trifid-plugin-graph-explorer",
  "description": "Trifid Graph Explorer plugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "version": "3.1.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/zazuko/trifid",
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/graph-explorer"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "scripts": {
    "coverage": "codecov",
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='**/types/**' --exclude='test/**' --exclude=dist --exclude=static --exclude=scripts --exclude=coverage --reporter=lcovonly --reporter=text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc && node scripts/copy-assets.ts"
  },
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "graph-explorer"
  ],
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "graph-explorer": "^2.0.0",
    "import-meta-resolve": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "fastify": "^5.10.0",
    "rimraf": "^6.1.3",
    "trifid-core": "workspace:^",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
