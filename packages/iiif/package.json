{
  "name": "@zazuko/trifid-plugin-iiif",
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Trifid plugin to handle IIIF data",
  "license": "Apache-2.0",
  "homepage": "https://github.com/zazuko/trifid#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/trifid.git",
    "directory": "packages/iiif"
  },
  "bugs": {
    "url": "https://github.com/zazuko/trifid/issues"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "c8 --all --exclude='**/*.d.ts' --exclude='**/types/**' --exclude='test/**' --exclude=dist --exclude=coverage --reporter=lcovonly --reporter=text node --conditions=source --test **/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf *.tgz dist/ coverage/",
    "build": "tsc"
  },
  "author": {
    "name": "Zazuko GmbH",
    "url": "https://zazuko.com/"
  },
  "keywords": [
    "trifid",
    "trifid-plugin",
    "iiif"
  ],
  "dependencies": {
    "@tpluscode/rdf-string": "^1.3.3",
    "@zazuko/env": "^3.0.1",
    "jsonld": "^9.0.0",
    "sparql-http-client": "^3.1.0",
    "through2": "^4.0.2"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/jsonld": "^1.5.15",
    "@types/node": "^25.5.0",
    "@types/sparql-http-client": "^3.1.0",
    "c8": "^11.0.0",
    "fastify": "^5.8.5",
    "rimraf": "^6.1.3",
    "trifid-core": "workspace:^",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
