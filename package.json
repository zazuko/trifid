{
  "name": "trifid-root",
  "private": true,
  "version": "0.0.0",
  "description": "Root package to handle all Trifid packages",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm run -r --if-present test",
    "release": "pnpm run build && changeset publish",
    "prepare": "husky",
    "build": "pnpm run -r --if-present build",
    "clean": "pnpm run -r --if-present clean"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "type-detect": "^4.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
