{
  "name": "trifid-root",
  "private": true,
  "version": "0.0.0",
  "description": "Root package to handle all Trifid packages",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm run -r --if-present test",
    "release": "changeset publish",
    "prepare": "husky",
    "build": "pnpm run --filter trifid-core build && pnpm run -r --if-present prepack",
    "clean": "pnpm run -r --if-present clean"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "type-detect": "^4.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
